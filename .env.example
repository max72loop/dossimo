# ---- Supabase ----
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the browser. Used by src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Resend (emailing, lead capture) ----
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=Dossimo <contact@dossimo.fr>
# Where landing-page lead notifications are sent
LEADS_NOTIFICATION_EMAIL=you@example.com

# ---- Stripe (paiement) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Tarification par palier selon la taille du dossier (prime estimee). Forfait
# FIXE, jamais un % de la prime. Surcharge optionnelle (JSON, centimes) ; le
# dernier palier sans "max" = sans plafond. Defauts : 49 / 99 / 149 EUR.
# STRIPE_PRICE_TIERS=[{"max":800,"cents":4900},{"max":2500,"cents":9900},{"cents":14900}]
# Forfait applique quand la prime n'est pas estimable (defaut 9900 = 99 EUR).
# STRIPE_PRICE_DEFAUT_CENTS=9900

# ---- OpenRouter (règles souples / points de vigilance rédigés) ----
# Passerelle LLM compatible OpenAI. Clé server-only. Le modèle est configurable.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507
# Modèle vision (extraction des devis/factures uploadés)
OPENROUTER_VLM_MODEL=google/gemini-2.5-flash-lite
# Modèle des points de vigilance : rapide (action synchrone) — surcharge optionnelle
OPENROUTER_VIGILANCE_MODEL=google/gemini-2.5-flash

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# E-mails autorisés à éditer les règles métier (/admin/regles), séparés par virgule
ADMIN_EMAILS=vous@entreprise.fr

# ---- Cron (expiration des crédits parrain) ----
# Secret partagé avec Vercel Cron. La route /api/cron/expire-credits exige
# l'en-tête Authorization: Bearer <CRON_SECRET>. Vercel l'envoie automatiquement
# quand cette variable est définie côté projet. Voir vercel.json (planif. 03:00).
CRON_SECRET=un-secret-long-et-aleatoire
