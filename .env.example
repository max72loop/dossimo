# ---- Supabase ----
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the browser. Used by src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Resend (emailing, lead capture) ----
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=Dossimo <contact@dossimo.fr>
# Where landing-page lead notifications are sent
LEADS_NOTIFICATION_EMAIL=you@example.com

# ---- Stripe (paiement) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- OpenRouter (règles souples / points de vigilance rédigés) ----
# Passerelle LLM compatible OpenAI. Clé server-only. Le modèle est configurable.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
