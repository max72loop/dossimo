# ---- Supabase ----
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the browser. Used by src/lib/supabase/admin.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Server-only. Stabilise le lien bénéficiaire unique même si la clé Supabase tourne.
# Générer une valeur aléatoire longue et conserver la même sur toutes les instances.
DEPOT_LINK_SECRET=your-long-random-secret

# ---- Google Apps Script (emailing des leads sans SMTP) ----
# URL /exec du déploiement Web App et secret identique à la propriété
# DOSSIMO_WEBHOOK_SECRET configurée dans le projet Apps Script.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_APPS_SCRIPT_WEBHOOK_SECRET=your-long-random-secret

# ---- Stripe (paiement) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# La grille tarifaire vit dans pricing_tiers : vitrine et paiement lisent la même source.

# ---- OpenRouter (règles souples / points de vigilance rédigés) ----
# Passerelle LLM compatible OpenAI. Clé server-only. Le modèle est configurable.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507
# Modèle vision (extraction des devis/factures uploadés)
OPENROUTER_VLM_MODEL=google/gemini-2.5-flash-lite
# Modèle des points de vigilance : rapide (action synchrone) — surcharge optionnelle
OPENROUTER_VIGILANCE_MODEL=google/gemini-2.5-flash

# ---- Vérification SIRET + RGE (annuaires officiels) ----
# Contrôle du SIRET (Annuaire des Entreprises / SIRENE) et de la qualification
# RGE (annuaire ADEME / France Rénov'). APIs publiques, sans clé.
#   reel (défaut) : interroge les annuaires officiels.
#   demo          : accepte n'importe quel SIRET via une entreprise fictive
#                   (démonstrations, tests, sans entreprise réelle).
#   off           : désactive la vérification (aucun appel réseau).
# Le SIRET de démo dédié 11111111111111 est reconnu même en mode « reel ».
# DOSSIMO_VERIFICATION_MODE=reel

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# E-mails autorisés à éditer les règles métier (/admin/regles), séparés par virgule
ADMIN_EMAILS=vous@entreprise.fr

# ---- Cron (expiration des crédits parrain) ----
# Secret partagé avec Vercel Cron. La route /api/cron/expire-credits exige
# l'en-tête Authorization: Bearer <CRON_SECRET>. Vercel l'envoie automatiquement
# quand cette variable est définie côté projet. Voir vercel.json (planif. 03:00).
CRON_SECRET=un-secret-long-et-aleatoire
